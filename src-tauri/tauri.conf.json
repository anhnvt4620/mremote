{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "M-Termius",
  "version": "0.5.0",
  "identifier": "app.m-termius.desktop",
  "build": {
    "frontendDist": "../ui-dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "M-Termius",
        "width": 1280,
        "height": 820,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "url": "http://127.0.0.1:2208/"
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "title": "M-Termius",
      "tooltip": "M-Termius — remote terminal"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "sidecar/**/*"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Remote terminal in your pocket",
    "longDescription": "M-Termius — multi-tab terminal, SSH, file explorer, code editor, git, docker and HTTP client served through a local web server, all in one desktop window.",
    "windows": {
      "wix": {
        "language": ["en-US"]
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {}
}
